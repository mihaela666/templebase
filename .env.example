# === Temple Base Environment Variables ===
# This project is INDEPENDENT. Do NOT reuse keys from other projects.

# Builder Code (ERC-8021 attribution - get yours from base.org/builders)
NEXT_PUBLIC_BUILDER_CODE=

# Upstash Redis (for leaderboard - create NEW database at upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Coinbase Developer Platform Paymaster (cdp.coinbase.com)
CDP_PAYMASTER_URL=

# App URL (for BaseAppGate deep link - your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=

# Privy App ID (optional - get from dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=
